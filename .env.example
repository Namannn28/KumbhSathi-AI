# Database
DATABASE_URL=DATABASE_URL="postgresql://postgres:Naman_2005@@@db.tstkjavbwzmiivjjyiln.supabase.co:5432/postgres"
# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI APIs
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# Translation
GOOGLE_TRANSLATE_API_KEY=your-google-translate-key

# Storage
VERCEL_BLOB_TOKEN=your-vercel-blob-token

# Pinecone (Vector DB)
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENVIRONMENT=your-pinecone-env
PINECONE_INDEX_NAME=kumbh-knowledge

# Sentry
SENTRY_DSN=your-sentry-dsn

# WhatsApp Business API (Twilio or Meta)
WHATSAPP_BUSINESS_TOKEN=your-whatsapp-business-token
WHATSAPP_BUSINESS_PHONE_ID=your-phone-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# AWS (Optional, for advanced features)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_CROWD_PREDICTION=true
ENABLE_FACE_RECOGNITION=true
ENABLE_WHATSAPP_BOT=true

# Demo Mode (for development - DISABLE IN PRODUCTION)
NODE_ENV=development
DEMO_MODE=true
