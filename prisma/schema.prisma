// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users and Authentication
model User {
  id            String     @id @default(cuid())
  phone         String?    @unique
  email         String?    @unique
  name          String?
  language      String     @default("hi")
  role          Role       @default(PILGRIM)
  sector        String?
  profileImage  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastActive    DateTime   @default(now())

  // Relations
  pilgrimProfile    PilgrimProfile?
  volunteerProfile  VolunteerProfile?
  emergencies       EmergencyEvent[]
  chats             ChatMessage[]
  lostPersonReports LostPerson[]      @relation("ReportedBy")
  accommodationBookings AccommodationBooking[]

  @@index([phone])
  @@index([role])
}

enum Role {
  PILGRIM
  VOLUNTEER
  POLICE
  MEDICAL
  ADMIN
}

model PilgrimProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  age               Int?
  homeDistrict      String?
  homeState         String?
  travelPurpose     String?
  physicalAbility   String?
  groupSize         Int      @default(1)
  accommodationId   String?
  accessibilityNeeds Json?
  specialNotes      String?
  faceEmbedding     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model VolunteerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    String?
  badgeNumber     String   @unique
  assignedSector  String
  shiftStart      DateTime?
  shiftEnd        DateTime?
  skills          Json?
  incidentsHandled Int     @default(0)
  verified        Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Locations and POIs
model Location {
  id              String     @id @default(cuid())
  name            String
  nameHi          String?
  locationType    LocationType
  latitude        Float
  longitude       Float
  sector          String
  isActive        Boolean    @default(true)
  crowdLevel      String     @default("low")
  crowdScore      Float      @default(0.0)
  crowdUpdated    DateTime?
  operatingHours  Json?
  metadata        Json?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  events          Event[]
  accommodations  Accommodation[]

  @@index([locationType])
  @@index([sector])
}

enum LocationType {
  GHAT
  TEMPLE
  MEDICAL_CAMP
  POLICE_POST
  TOILET
  WATER_STATION
  FOOD_STALL
  PARKING
  FERRY
  INFO_KIOSK
  CAMPING_AREA
}

// Accommodations
model Accommodation {
  id              String     @id @default(cuid())
  name            String
  nameHi          String?
  type            AccommodationType
  locationId      String
  location        Location   @relation(fields: [locationId], references: [id])
  latitude        Float
  longitude       Float
  sector          String
  capacity        Int
  availableUnits  Int
  priceMin        Int?
  priceMax        Int?
  amenities       Json?
  contactPhone    String?
  contactWhatsapp String?
  verified        Boolean    @default(false)
  rating          Float?
  reviewCount     Int        @default(0)

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  bookings        AccommodationBooking[]

  @@index([sector])
  @@index([type])
}

enum AccommodationType {
  TENT
  DHARAMSHALA
  HOTEL
  ASHRAM
  CAMP
}

model AccommodationBooking {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  accommodationId String
  accommodation   Accommodation @relation(fields: [accommodationId], references: [id])
  checkInDate     DateTime
  checkOutDate    DateTime
  numberOfGuests  Int
  totalPrice      Int?
  status          BookingStatus @default(PENDING)
  notes           String?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([userId])
  @@index([accommodationId])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

// Events
model Event {
  id                String   @id @default(cuid())
  name              String
  nameHi            String?
  eventType         String?
  locationId        String
  location          Location @relation(fields: [locationId], references: [id])
  startTime         DateTime
  endTime           DateTime
  expectedAttendance Int?
  significanceHi    String?
  significanceEn    String?
  isSnan            Boolean  @default(false)
  snanType          String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isSnan])
  @@index([startTime])
}

// Emergency Events
model EmergencyEvent {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emergencyType   EmergencyType
  severity        EmergencySeverity
  status          EmergencyStatus @default(REPORTED)
  latitude        Float?
  longitude       Float?
  sector          String?
  description     String?
  aiSummary       String?
  aiUrgencyScore  Float?
  assignedToId    String?

  reportedAt      DateTime @default(now())
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([severity])
  @@index([sector])
}

enum EmergencyType {
  MEDICAL
  LOST_CHILD
  WOMEN_SAFETY
  STAMPEDE
  FIRE
  CROWD_SURGE
  OTHER
}

enum EmergencySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EmergencyStatus {
  REPORTED
  ACKNOWLEDGED
  DISPATCHED
  RESOLVED
  FALSE_ALARM
}

// Lost & Found
model LostPerson {
  id                    String   @id @default(cuid())
  reportedById          String
  reportedBy            User     @relation("ReportedBy", fields: [reportedById], references: [id], onDelete: Cascade)
  missingName           String
  age                   Int?
  gender                String?
  lastSeenLatitude      Float?
  lastSeenLongitude     Float?
  lastSeenSector        String?
  lastSeenTime          DateTime?
  clothingDescription   String?
  faceEmbedding         String?
  photoUrl              String?
  status                LostPersonStatus @default(SEARCHING)
  foundLatitude         Float?
  foundLongitude        Float?
  foundTime             DateTime?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status])
  @@index([lastSeenSector])
}

enum LostPersonStatus {
  SEARCHING
  FOUND
  RESOLVED
  CLOSED
}

// Crowd Snapshots
model CrowdSnapshot {
  id              String   @id @default(cuid())
  timestamp       DateTime @default(now())
  sector          String
  densityScore    Float    @default(0.0)
  personCount     Int      @default(0)
  movementVector  Json?
  dataSources     String[]
  predictions     Json?

  @@index([sector])
  @@index([timestamp])
}

// FAQ and Knowledge Base
model FaqDocument {
  id              String   @id @default(cuid())
  question        String
  questionHi      String?
  answer          String
  answerHi        String?
  category        String
  tags            String[]
  language        String   @default("en")
  embedding       String?
  authority       Int      @default(1)
  recency         Int      @default(100)
  sector          String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([language])
}

// Chat History
model ChatMessage {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId       String
  role            ChatRole
  content         String
  inputType       String?
  audioUrl        String?
  imageUrl        String?
  agentUsed       String?
  retrievedSources String[]
  latencyMs       Int?
  feedback        String?

  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
}

enum ChatRole {
  USER
  ASSISTANT
}

// WhatsApp Sessions
model WhatsappSession {
  id              String   @id @default(cuid())
  phoneNumber     String   @unique
  sessionData     Json?
  lastMessageAt   DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Translations Cache
model TranslationCache {
  id              String   @id @default(cuid())
  sourceText      String
  sourceLang      String
  targetLang      String
  translatedText  String

  createdAt       DateTime @default(now())

  @@unique([sourceText, sourceLang, targetLang])
  @@index([sourceLang])
}

// Alerts
model Alert {
  id              String   @id @default(cuid())
  alertType       String
  severity        AlertSeverity
  affectedSectors String[]
  messageHi       String?
  messageEn       String?
  createdById     String?
  activeFrom      DateTime @default(now())
  activeUntil     DateTime?
  sentCount       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([alertType])
  @@index([activeFrom])
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
